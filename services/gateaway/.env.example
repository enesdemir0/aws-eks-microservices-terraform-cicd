APP_NAME=AI_Gateway
NODE_ENV=development
PORT=8000
LOG_LEVEL=INFO

AUTH_SERVICE_URL=http://localhost:3000
AUTH_SERVICE_TIMEOUT=5.0

STORAGE_TYPE=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
AWS_S3_BUCKET=

REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=image_tasks
