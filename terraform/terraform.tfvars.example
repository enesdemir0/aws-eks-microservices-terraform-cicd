# Copy this file to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it contains secrets.

aws_region   = "us-east-1"
project_name = "visionmetric"
environment  = "production"

# EKS — keep node count at 2 to cap EC2 costs
eks_cluster_version = "1.29"
node_instance_type  = "t3.medium"
node_desired_count  = 2
node_min_count      = 1
node_max_count      = 2

# RDS — single Free Tier instance shared by auth + metadata
db_username = "visionmetric"
db_password = "CHANGE_ME_strong_password_123!"   # min 8 chars, required

# Kubernetes namespace where gateway/ai-worker pods run
k8s_worker_namespace = "visionmetric"
